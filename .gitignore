# Dependencies
node_modules/

# Database (auto-created on first run)
prism.db
prism.db-wal
prism.db-shm

# DB snapshots from /api/admin/backup-db (never commit these — contain prod data)
backups/

# Environment (secrets)
.env

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
.claude/

# Build artifacts
build/
dist/
.netlify/

# Operational reports (local-only; not deliverables)
reports/

# Pre-edit snapshots
*.bak

# Large binary design assets (Photoshop / Illustrator / sketch).
# These belong in Revenue_Workstreams/ workstream folders, never inside the dashboard repo.
*.psd
*.psd.zip
*.ai
*.sketch

# Per-task PR-body scratch files written during PR creation. Kept out of the
# repo so they don't accumulate after merge.
.PR_BODY_*.md

