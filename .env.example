# ─────────────────────────────────────────────────────
# PRISM AI Analytics — Dashboard Environment Variables
# ─────────────────────────────────────────────────────
# LOCAL DEV:   Copy this file to .env
# RAILWAY:     Set these in the Railway service Variables tab
# ─────────────────────────────────────────────────────

# Server port
# Railway sets this automatically — do NOT set it in Railway
PORT=3000

# API authentication
# REQUIRED IN PRODUCTION — set a strong random string (32+ chars)
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave blank for local dev only
API_KEY=

# CORS — restrict to your Railway URL in production
# Local:       http://localhost:3000
# Production:  https://your-app.up.railway.app
CORS_ORIGIN=*

# Node environment
NODE_ENV=production

# App environment — controls demo banner and auto-seed behavior
# Values: production (default), demo
# Set to 'demo' on staging/UAT instances
APP_ENV=production

# Stripe — Payment Processing & Revenue
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# QuickBooks Online — Accounting & P&L
# Get from: https://developer.intuit.com/app/developer/dashboard
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REALM_ID=
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
QBO_ENVIRONMENT=production

# Skilljar — CCA Certification Progress Tracking
# Get from: Skilljar Dashboard → Organization → API Credentials
SKILLJAR_API_KEY=
SKILLJAR_DOMAIN=
# Comma-separated team member emails to track
SKILLJAR_EMAILS=michele@prismaianalytics.com,izayah@prismaianalytics.com

# Notion — TASKS.md ↔ Dashboard ↔ Notion sync (T-015)
# Internal integration secret from https://www.notion.com/my-integrations
# Used by scripts/sync-tasks.js to mirror engineering tickets to the "Prism AI Tickets" DB
NOTION_API_KEY=
NOTION_TICKETS_DB_ID=b3b42787-e56b-4807-afcc-ee172df50cb9
